{
  "name": "nrepubreader",
  "version": "1.0.1",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "generate:reader-vendor": "node scripts/generate-reader-vendor-assets.js",
    "start": "npm run generate:reader-vendor && expo start --dev-client",
    "android": "npm run generate:reader-vendor && expo run:android",
    "ios": "npm run generate:reader-vendor && expo run:ios",
    "web": "npm run generate:reader-vendor && expo start --web",
    "setup:android-release-keystore": "bash scripts/setup-android-release-keystore.sh",
    "build:android:release-apks": "npm run generate:reader-vendor && bash scripts/build-android-release-apks.sh",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@expo-google-fonts/noto-sans-sc": "^0.4.0",
    "@react-navigation/native": "^7.1.14",
    "@react-navigation/native-stack": "^7.3.21",
    "epubjs": "0.3.93",
    "expo": "^55.0.0",
    "expo-asset": "~55.0.17",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "~55.0.33",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.20",
    "expo-font": "~55.0.7",
    "expo-modules-core": "~55.0.25",
    "expo-sqlite": "~55.0.16",
    "expo-status-bar": "~55.0.6",
    "fast-xml-parser": "^5.2.5",
    "jszip": "^3.10.1",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-webview": "13.16.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "babel-preset-expo": "~55.0.21",
    "eslint": "^9.36.0",
    "eslint-config-expo": "~55.0.1",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.0",
    "typescript": "~5.9.2"
  }
}
